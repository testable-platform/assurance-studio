# Copy to .env.local and fill in values
#
# QA (https://qa-frontend.testable.cc/auth/login)
IDENTITY_URL=https://qa-api.testable.cc
RUNTIME_URL=https://qa-runtime.testable.cc
VIEWS_URL=https://qa-views.testable.cc
FRONTEND_URL=https://qa-frontend.testable.cc
#
# Local dev
# IDENTITY_URL=http://localhost:8000
# RUNTIME_URL=http://localhost:8002
# VIEWS_URL=http://localhost:8003
# FRONTEND_URL=http://localhost:3000

AUTH_EMAIL=your@email.com
AUTH_PASSWORD=your-password

# Optional — resolved automatically from login session on QA/live
TENANT_ID=
USER_ID=
# Optional — auto-selected when unset (CLI/notebook only; UI uses per-user repo picker)
PROJECT_ID=
# GitHub App OAuth (Testable Assurance Studio — github.com/settings/apps)
# Callback URL must match GITHUB_OAUTH_REDIRECT_URI exactly (e.g. http://localhost:8501/)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8501/
GITHUB_APP_SLUG=testable-assurance-studio
SCM_TOKEN_SECRET=change-me-to-a-long-random-string
SCM_DB_PATH=scm_connections.db

# Classic PAT for branch push (repo scope). Preferred over GitHub App token when set.
# Create at github.com/settings/tokens — enable the **repo** scope for write access.
GITHUB_TOKEN=

# Optional dev default for CLI/notebook catalog match (NOT used as shared UI push target).
# Each user picks their repository via GitHub OAuth in the app; stored per user in scm_connections.db.
REPOSITORY_MATCH=

BRANCHES=SA_DOV_Bug_2.6,SA_DOV_BugFX_2.6,SA_DOV_TCC_2.6,SA_DOV_CC_2.6
OUTPUT_DIR=taxonomy_reports
REPORT_CLASSIFICATION=Structural Analysis
EXPORT_HTML=true
HTML_ONLY=true
POLL_INTERVAL_SEC=30
POLL_TIMEOUT_SEC=3600
TAXONOMY_POLL_TIMEOUT_SEC=3600
REQUIRE_RUN_COMPLETED=false
CONTINUE_ON_FAILURE=true
PREFER_GITHUB_COMMIT=true
BRANCH_DELAY_SEC=90
RUN_CREATE_MAX_RETRIES=15
RUN_CREATE_RETRY_SEC=120

# Local tools — isolated throwaway venv per batch (default true; UI checkbox overrides)
LOCAL_TOOL_ISOLATED=true

# SonarQube Community (optional — defaults work with local Docker)
# SONAR_HOST_URL=http://localhost:9000
# SONAR_CONTAINER_NAME=tas-sonarqube
# SONAR_DOCKER_IMAGE=sonarqube:community
# SONAR_SCANNER_IMAGE=sonarsource/sonar-scanner-cli
